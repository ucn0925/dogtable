<div class="container mt-4 shop-index">

  <h1 class="page-title">店鋪一覧</h1>

  <!-- 検索フォーム -->
  <%= form_with url: shops_path, method: :get, local: true do %>
    <div class="d-flex gap-2 align-items-center my-3">

      <%= text_field_tag :keyword, 
          params[:keyword],
          placeholder: "店名検索",
          class: "form-control",
          style: "max-width: 200px;" %>
      
      <%= select_tag :genre_id,
          options_from_collection_for_select(Genre.all, :id, :name, params[:genre_id]),
          include_blank: "ジャンルを選択",
          class: "form-select",
          style: "max-width: 180px;" %>

      <%= select_tag :sort, 
          options_for_select([
            ['並び替え', ''],
            ['評価が高い順', 'rating'],
            ['口コミが多い順', 'posts'],
            ['新着順', 'new']
          ], params[:sort]),
          class: "form-select",
          id: "sort-select",
          style: "max-width: 180px;" %>  

      <%= submit_tag "検索", class: "dt-btn dt-btn-primary dt-btn-search" %>
    </div>
  <% end %>

<hr>

  <% if params[:keyword].present? || params[:genre_id].present? || params[:area_id].present? || params[:sort].present? %>
    <!-- 検索結果情報 -->
    <div class="mt-3 mb-4">
      <p class="mb-1">検索結果：<%= @shops.total_count %>件</p>
      <%= link_to "検索条件をリセット", shops_path, class: "reset-link" %>
    </div>
  <% end %>

    <!-- 店舗一覧 -->
    <% if @shops.any? %>
      <% @shops.each do |shop| %>
        <%= link_to shop_path(shop), class: "shop-card-link" do %>
          <div class="card shop-card mb-3 mx-auto">
            <div class="d-flex align-items-start gap-4">

            <!-- サムネイル -->
            <% if shop.images.attached? %>
              <%= image_tag shop.images.first.variant(resize_to_fill: [120, 120]),
                    class: "shop-thumbnail" %>
            <% else %>
              <div class="shop-no-image">
                <i class="fa-solid fa-image"></i>
                <span>NO IMAGE</span>
              </div>
            <% end %>

            <!-- 店舗情報 -->
            <div>
              <h2 class="h5 mb-1 shop-name"><%= shop.name %></h2>

                <% avg = shop.posts.average(:rating_overall).to_f %>

                <div class="shop-rating mb-1">

                  <% 5.times do |i| %>
                    <span class="<%= i < avg.round ? 'dt-star' : 'dt-star-muted' %>">★</span>
                  <% end %>

                  <span class="rating-number">
                    <%= number_with_precision(avg, precision: 1) %>
                  </span>

                </div>

              <p class="mb-1"><%= shop.address %></p>

              <p class="mb-1"><%= shop.genre.name %> ／ <%= shop.block.name %></p>

              <div class="dog-info mb-1">
              
                <% if shop.inside_ok? %>
                  <span class="dog-badge">
                    <i class="fa-solid fa-house"></i>
                      店内OK
                  </span>
                <% end %>

                <% if shop.terrace_ok? %>
                  <span class="dog-badge">
                    <i class="fa-solid fa-leaf"></i>
                      テラスOK
                  </span>
                <% end %>

              </div>

              <p class="shop-meta mb-0">
                <span class="meta-item">
                  <i class="fa-regular fa-heart"></i>
                  <span class="meta-count"><%= shop.shop_favorites.count %></span>
                </span>

                <span class="meta-item ms-3">
                  <i class="fa-regular fa-comment"></i>
                  <span class="meta-count"><%= shop.posts.count %></span>
                </span>

              </p>

            </div>

            </div>
          </div>
        <% end %>
      <% end %>

      <%= paginate @shops %>

    <% else %>
      <p>該当する店舗が見つかりませんでした。</p>
    <% end %>

  <!-- 新規店舗登録ボタン -->
  <div class="d-flex justify-content-center mt-4 mb-5">
    <%= link_to "新しい店舗を登録する", new_shop_path, class: "dt-btn dt-btn-primary dt-btn-lg" %>
  </div>

</div>
