<div class="container mt-2 mb-4 shop-show">

  <!-- 戻るリンク -->
  <div class="mb-2">
    <%= link_to shops_path, 
          class: "text-muted small text-decoration-none d-inline-flex align-items-center" do %>
      << 一覧に戻る
    <% end %>
  </div>

  <!-- 店名 -->
  <h1 class="h3 mt-2 mb-2"><%= @shop.name %></h1>

  

  <!-- 基本情報カード -->
  <div class="card mt-3 mb-4">
    <div class="card-body">

      <h4 class="h6 fw-bold fs-5 border-start border-4 ps-3 mt-2 mb-4">店舗情報</h4>

      <!-- 情報バー -->
      <div class="d-flex justify-content-between align-items-center mb-4">

        <!-- 左側：評価・お気に入り・コメント -->
        <div class="dt-meta-bar d-flex align-items-center gap-4 text-muted small">

          <% if @average_rating.present? %>
            <div class="d-flex align-items-center">
              <% 5.times do |i| %>
                <span class="<%= i < @average_rating.floor ? 'dt-star' : 'dt-star-muted' %>">★</span>
              <% end %>
              <span class="ms-1">
                <%= number_with_precision(@average_rating, precision: 2) %>
              </span>
            </div>
          <% end %>

          <div>
            <i class="fa-regular fa-heart me-1"></i>
            <%= @shop.shop_favorites.count %>
          </div>

          <div>
            <i class="fa-regular fa-comment me-1"></i>
            <%= @shop.posts.count %>
          </div>

        </div>

        <!-- 右側：行きたいボタン -->
        <% if user_signed_in? %>
          <% wanted = current_user.shop_favorites.exists?(shop_id: @shop.id) %>
              
          <%= link_to shop_shop_favorite_path(@shop),
                data: { turbo_method: wanted ? :delete : :post },
                class: "dt-want-btn #{'active' if wanted}" do %>
              
            <i class="<%= wanted ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
            <span class="ms-1">行きたい</span> 
              
          <% end %>      
        <% end %>

      </div>

      <hr class="my-3">


      <dl class="row mb-0">
        <dt class="col-4 dt-label">
          <i class="fa-solid fa-location-dot dt-label-icon me-1"></i>
          住所
        </dt>
        <dd class="col-8"><%= @shop.address %></dd>

        <dt class="col-4 dt-label">
          <i class="fa-solid fa-utensils dt-label-icon me-1"></i>
          ジャンル
        </dt>
        <dd class="col-8"><%= @shop.genre.name %></dd>

        <dt class="col-4 dt-label">
          <i class="fa-solid fa-clock dt-label-icon me-1"></i>
          営業時間
        </dt>
        <dd class="col-8"><%= @shop.opening_hours.presence || "未登録" %></dd>

        <dt class="col-4 dt-label">
          <i class="fa-solid fa-calendar-days dt-label-icon me-1"></i>
          定休日
        </dt>
        <dd class="col-8"><%= @shop.closed_days.presence || "未登録" %></dd>

        <dt class="col-4 dt-label">
          <i class="fa-solid fa-car dt-label-icon me-1"></i>
          駐車場
        </dt>
        <dd class="col-8"><%= @shop.parking ? "あり" : "なし" %></dd>
      </dl>

      <hr class="my-3">

      <h4 class="h6 fw-bold fs-5 border-start border-4 ps-3 mb-4">犬連れ情報</h4>

      <dl class="row mb-0">
        <dt class="col-4 dt-label">
          <i class="fa-solid fa-house dt-label-icon me-1"></i>
          店内同伴OK
        </dt>
        <dd class="col-8">
          <% if @shop.inside_ok? %>
            <span class="dt-badge dt-badge-ok">
              <i class="fa-solid fa-circle-check me-1"></i>
              可
            </span>
          <% else %>
            <span class="dt-badge dt-badge-ng">
              <i class="fa-solid fa-circle-xmark me-1"></i>
              不可
            </span>
          <% end %>
        </dd>

        <dt class="col-4 dt-label">
          <i class="fa-solid fa-leaf dt-label-icon me-1"></i>
          テラスOK
        </dt>
        <dd class="col-8">
          <% if @shop.terrace_ok? %>
            <span class="dt-badge dt-badge-ok">
              <i class="fa-solid fa-circle-check me-1"></i>
              可
            </span>
          <% else %>
            <span class="dt-badge dt-badge-ng">
              <i class="fa-solid fa-circle-xmark me-1"></i>
              不可
            </span> 
          <% end %>
        </dd>

        <dt class="col-4 dt-label">
          <i class="fa-solid fa-bone dt-label-icon me-1"></i>
          犬用メニューあり
        </dt>
        <dd class="col-8">
          <% if @shop.dog_menu? %>
            <span class="dt-badge dt-badge-ok">
              <i class="fa-solid fa-circle-check me-1"></i>
              可
            </span>
          <% else %>
            <span class="dt-badge dt-badge-ng">
              <i class="fa-solid fa-circle-xmark me-1"></i>
              不可
            </span>
          <% end %>
        </dd>

        <dt class="col-4 dt-label">
          <i class="fa-solid fa-link dt-label-icon me-1"></i>
          リードフックあり
        </dt>
        <dd class="col-8">
          <% if @shop.lead_hook? %>
            <span class="dt-badge dt-badge-ok">
              <i class="fa-solid fa-circle-check me-1"></i>
              可
            </span>
          <% else %>
            <span class="dt-badge dt-badge-ng">
              <i class="fa-solid fa-circle-xmark me-1"></i>
              不可
            </span>
          <% end %>
        </dd>
      </dl>

      <hr class="my-3">


      <!-- 店舗写真 -->
      <% if @shop.images.attached? %>
        <h4 class="h6 fw-bold fs-5 border-start border-4 ps-3 mb-4">店舗写真</h4>

        <div class="d-flex flex-wrap gap-2 mb-2">
          <% @shop.images.each do |image| %>
            <%= link_to url_for(image), 
                  class: "glightbox",
                  data: { gallery: "shopt-#{@shop.id}" } do %>
              <%= image_tag image.variant(resize_to_fill: [250, 250]), 
                    class: "shop-photo" %>
            <% end %>
          <% end %>
        </div>

      <% end %>

			<hr class="my-3">

    </div>
  </div>

  <hr>

  <!-- 口コミ一覧 -->
  <div class="d-flex justify-content-between align-items-center mt-4">
    <h3 class="h4 mt-4">口コミ一覧</h3>

    <% if user_signed_in? %>
      <a href="#new-post" class="dt-btn dt-btn-outline dt-btn-outline-accent dt-btn-sm">
        ＋ 口コミを投稿する
      </a>
    <% end %>
  </div>

  <% if @shop.posts.any? %>
    <% @shop.posts.includes(:user).order(created_at: :desc).each do |post| %>
    
      <div class="card mb-3 position-relative">
        <div class="card-body">

          <!-- カード全体クリック -->
          <%= link_to "", shop_post_path(@shop, post), class: "stretched-link" %>

          <!-- ユーザー名 & 投稿日 -->
          <div class="d-flex justify-content-between align-items-center mb-2">

            <div class="d-flex align-items-center">
              <% if post.user&.profile_image&.attached? %>
                <%= image_tag post.user.profile_image.variant(resize_to_fill: [40, 40]),
                      class: "avatar avatar-sm me-2"%>
              <% else %>
                <div class="avatar avatar-sm avatar-placeholder me-2">
                  <i class="fa-solid fa-user"></i>
                </div>
              <% end %>
              
              <div>
                <strong>
                  <% if post.user.present? %>
                    <%= link_to post.user.name, user_path(post.user), class: "user-link" %>
                  <% else %>
                    退会ユーザー
                  <% end %>
                </strong>
                
                <div class="text-muted small">
                  <%= post.created_at.strftime("%Y/%m/%d %H:%M") %>
                </div>

              </div>
            </div>

            <% if post.user == current_user %>
              <div>
                <%= link_to "編集", edit_shop_post_path(@shop, post), class: "text-primary me-2" %>
                <%= link_to "削除", shop_post_path(@shop, post), 
                      data: { turbo_method: :delete, turbo_confirm: "この投稿を削除しますか？" },
                      class: "text-danger" %>
              </div>
            <% end %>
          </div>
    
          <!-- 評価表示 -->
          <div class="dt-rating-block mb-2">
            
            <div class="dt-overall-rating">
              <% (1..5).each do |i| %>
                <span class="<%= i <= (post.rating_overall || 0) ? 'dt-star' : 'dt-star-muted' %>">★</span>
              <% end %>
              <span class="dt-score ms-2">
                <%= number_with_precision(post.rating_overall, precision: 1) %>
              </span>
            </div>

            <div class="dt-sub-rating">

              <div class="dt-sub-item">
                <span class="dt-sub-label">料理</span>
                <% (1..5).each do |i| %>
                  <span class="<%= i <= (post.rating_food || 0) ? 'dt-star' : 'dt-star-muted' %>">★</span>
                <% end %>
              </div>

              <div class="dt-sub-item">
                <span class="dt-sub-label">犬連れ</span>
                <% (1..5).each do |i| %>
                  <span class="<%= i <= (post.rating_dog_friendliness || 0) ? 'dt-star' : 'dt-star-muted' %>">★</span>
                <% end %>
              </div>

            </div>

          </div>

          <!-- コメント内容 -->
          <div class="mt-2">
            <% if post.images.attached? %>
              <div class="d-flex flex-wrap gap-2 mb-2">
                <% post.images.each do |image| %>
                  <%= link_to url_for(image), 
                        class: "glightbox",
                        data: { gallery: "post-#{post.id}" } do %>
                    <%= image_tag image.variant(resize_to_fill: [250, 250]), 
                        class: "shop-photo" %>
                  <% end %>
                <% end %>
              </div>
            <% end %>

            <%= link_to shop_post_path(@shop, post),
                  class: "text-dark text-decoration-none" do %>
              <%= simple_format(h(post.content)) %>
            <% end %>
          </div> 

          <% if post.visited_on.present? %>
            <div class="review-meta mt-2 small text-muted d-flex align-items-center gap-3">
              <span>
                <i class="fa-solid fa-calendar-day me-1"></i>
                <%= post.visited_on.strftime("%Y/%m/%d") %>
              </span>

              <% if post.dog_size.present? %>
                with
                <%= case post.dog_size
                    when "small" then "小型犬"
                    when "medium" then "中型犬"
                    when "large" then "大型犬"
                    else ""
                    end %>
              <% end %>

            </div>
          <% end %>

        </div>
      </div>

    <% end %>

  <% else %>
    <p>まだ口コミはありません。</p>
  <% end %>

  <!-- 新規投稿 -->
  <div class="card mt-5" id="new-post">
    <div class="card-body">
      <h2 class="h4 mb-3">口コミを投稿する</h2>

      <% if user_signed_in? %>
        <% new_post = @shop.posts.build %>

        <%= form_with(model: [@shop, new_post], local: true) do |f| %>
          <%= render "posts/form", post:new_post, shop: @shop, f: f %>
        <% end %>
      <% else %>
        <p>口コミを投稿するにはログインが必要です。</p>
      <% end %>
    </div>
  </div>

	<div class="card mt-4 border-secondary">
    <div class="card-body">
      <small class="text-muted d-block mb-2">この店舗の管理</small>
      
      <%= link_to "店舗情報を編集", 
            edit_shop_path(@shop),
            class: "dt-btn dt-btn-outline dt-btn-outline-soft dt-btn-sm me-2" %>

      <%= link_to "店舗を削除", 
            shop_path(@shop), 
            data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？"},
            class: "dt-btn dt-btn-danger dt-btn-sm" %>
    </div>
  </div>

</div>