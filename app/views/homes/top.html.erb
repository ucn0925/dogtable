<div class="hero">
  <div class="hero__inner container text-center"> 

    <!-- サイト名 -->
    <h1 class="display-5 fw-bold mb-2">DogTable</h1>
    
    <!-- テーマ -->
    <p class="lead mb-4">おいしいも、一緒がいい。</p>

    <!-- 検索ボックス一式 -->
    <div class="search-card mx-auto">
      <%= form_with url: shops_path, method: :get, local: true do %>

        <!-- フリーワード検索（上段） -->
        <div class="d-flex justify-content-center mb-3">
          <%= text_field_tag :keyword, params[:keyword],
              placeholder: "店名で検索",
              class: "form-control",
              style: "max-width: 520px;"
          %>
        </div>
      
        <!-- エリア＆ジャンル（下段） -->
        <div class="d-flex flex-wrap justify-content-center gap-2 mb-2">

          <!-- エリア（blockとcity） -->
          <%= select_tag :area_id,
                options_for_select(@area_options, params[:area_id]),
                include_blank: "エリア",
                class: "form-select",
                style: "width: 170px;" 
          %>

          <!-- ジャンル選択 -->
          <%= select_tag :genre_id,
                options_from_collection_for_select(Genre.all, :id, :name, params[:genre_id]),
                include_blank: "ジャンル",
                class: "form-select",
                style: "width: 170px;"
          %>

          <!-- 検索ボタン -->
          <%= submit_tag "検索", class: "dt-btn dt-btn-primary dt-btn-search" %>
        </div>

      <% end %>

      <!-- 地図で探すリンク -->
      <%= link_to "地図から探す", map_path, class: "hero-link d-inline-block mt-2" %>
    </div>
  </div>
</div>

<div class="container mt-5">

  <h2 class="mb-3">新着口コミ</h2>

  <% if @recent_posts.present? %>

    <% @recent_posts.each do |post| %>
      <div class="card mb-3 p-3">

        <h5>
          <%= link_to post.shop.name, shop_path(post.shop) %>
        </h5>

        <p class="mb-1">
          <%= post.content %>
        </p>

        <small class="text-muted">
          <%= post.user.name %> ・ <%= post.created_at.strftime("%Y/%m/%d") %>
        </small>

      </div>
    <% end %>
  
  <% else %>

    <p class="text-muted">まだ口コミがありません</p>

  <% end %>

</div>

