<div class="container py-4"> 

  <% if @posts.any? %> 
    <% @posts.each do |post| %>
      
      <div class="timeline-card position-relative">

        <%= link_to "", shop_post_path(post.shop, post), class: "stretched-link" %>

        <div class="timeline-shop">
          <%= link_to post.shop.name, shop_path(post.shop), onclick: "event.stopPropagation();" %>
          <span class="shop-area">
            （<%= post.shop.city.name %>）
          </span>
        </div>

        <div class="timeline-header">
          <% if post.user.profile_image.attached? %>
            <%= image_tag post.user.profile_image, class: "avatar avatar-sm" %>
          <% else %>
            <%= image_tag "default_user.png", class: "avatar avatar-sm" %>
          <% end %>

          <div>
            <strong><%= post.user.name %></strong><br>
            <small class="text-muted">
              <%= post.created_at.strftime("%Y/%m/%d %H:%M") %>
            </small>
          </div>
        </div>

        <div class="timeline-body">

          <div class="timeline-content">

            <div class="timeline-rating">
              <% 5.times do |i| %>
                <span class="<%= i < post.rating_overall.to_i ? 'dt-star' : 'dt-star-muted' %>">★</span>
              <% end %>
            </div>

            <% if post.content.present? %>
              <p class="timeline-comment">
                <%= truncate(post.content, length: 60) %>
              </p>
            <% end %>


            <div class="timeline-like">
              <% if post.favorited_by?(current_user) %>
                <%= button_to shop_post_post_favorite_path(post.shop, post),
                      method: :delete,
                      class: "btn btn-danger btn-sm rounded-pill" do %>
                  ❤︎ いいね済み
                <% end %>
              <% else %>
                <%= button_to shop_post_post_favorite_path(post.shop, post),
                      method: :post,
                      class: "btn btn-outline-danger btn-sm rounded-pill" do %>
                  ♡いいね
                <% end %>
              <% end %>
            </div>

          </div>

          <% if post.images.attached? %>
            <div class="timeline-images">
              <% post.images.first(2). each do |image| %>
                <%= image_tag image %>
              <% end %>
            </div>
          <% end %>

        </div>
      </div>
      
    
    <% end %>

  <% else %>
    <p>フォローしている人の投稿はまだありません。</p>
  <% end %> 
</div>
