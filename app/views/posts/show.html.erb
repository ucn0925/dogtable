<div class="container py-4">

  <div class="mb-3">
    <%= link_to "<< 店舗ページに戻る", shop_path(@shop), class: "back-link" %>
  </div>

  <div class="post-detail-card">

    <!--ユーザー情報 -->
    <div class="post-header">

      <div class="post-user-wrap">

        <% if @post.user.profile_image.attached? %>
          <%= image_tag @post.user.profile_image, class: "avatar avatar-md" %>
        <% else %>
          <%= image_tag "default_user.png", class: "avatar avatar-md" %>
        <% end %>

        <div class="post-user-meta">
          <strong class="post-user">
            <%= link_to @post.user.name, user_path(@post.user) %>
          </strong>

          <% if @post.visited_on.present? %>
            <div class="post-visit-info">
              <%= @post.visited_on.strftime("%Y/%m") %>訪問

              <% if @post.dog_size.present? %>
                <span class="dog-info ms-2">
                  with
                  <%= case @post.dog_size
                    when "small" then "小型犬"
                    when "medium" then "中型犬"
                    when "large" then "大型犬"
                  end %>

                  <% if @post.user.dog&.dog_image&.attached? %>
                    <%= image_tag @post.user.dog.dog_image, class: "dog-icon" %>
                  <% else %>
                    <%= image_tag "default_dog.png", class: "dog-icon" %>
                  <% end %>
                </span>
              <% end %>

            </div>
          <% end %>

        </div>
      </div>

      <% if current_user == @post.user %>
        <div class="post-actions">
          <%= link_to edit_shop_post_path(@shop, @post), class: "post-action-icon" do %>
            <i class="fa-regular fa-pen-to-square"></i>
          <% end %>

          <%= link_to shop_post_path(@shop, @post),
                data: { turbo_method: :delete, turbo_confirm: "削除してよろしいですか？" },
                class: "post-delete-icon" do %>
            <i class="fa-regular fa-trash-can"></i>
          <% end %>
        </div>
      <% end %>

    </div>

    <!-- 評価 -->
    <div class="post-rating">

      <% [["総合評価", @post.rating_overall],
          ["料理", @post.rating_food],
          ["dog friendly", @post.rating_dog_friendliness]].each do |label, rating| %>
        
        <div class="post-rating-item">
          <div class="post-rating-label"><%= label %>：</div>
          <div>
            <% 5.times do |i| %>
              <span class="<%= i < rating.to_i ? 'dt-star' : 'dt-star-muted' %>">★</span>
            <% end %>
          </div>
        </div>

      <% end %>
    
    </div>

    <!-- コメント -->
    <div class="comment-section">

      <div class="dt-comment-box">
        <div class="dt-comment-text">
          <%= simple_format(h(@post.content)) %>
        </div>

        <div class="dt-like-wrap">
          <div class="dt-like-left">
            <%= button_to shop_post_post_favorite_path(@shop, @post),
                  method: @post.favorited_by?(current_user) ? :delete : :post,
                  class: "dt-like-btn" do %>
            
              <% if @post.favorited_by?(current_user) %>
                <i class="fa-solid fa-heart"></i>
              <% else %>
                <i class="fa-regular fa-heart"></i>
              <% end %>
            
            <% end %>

            <span class="dt-like-count">
              <%= @post.post_favorites.count %>
            </span>
          </div>

          <span class="dt-post-date">
            <%= @post.created_at.strftime("%Y/%m/%d %H:%M") %>
          </span>

        </div>
      </div>   
    </div>

    <!-- 投稿画像 -->
    <% if @post.images.attached? %>
      <div class="post-images">
        <% @post.images.first(2).each do |image| %>
          <%= link_to url_for(image),
                class: "glightbox",
                data: { gallery: "post-#{@post.id}" } do %>
            <%= image_tag image.variant(resize_to_limit: [250, 250]),
                  class: "img-fluid rounded shadow-sm",
                  style: "width: 250px; height: 250px; object-fit: cover;" %>
          <% end %>
        <% end %>
      </div>

      <% if @post.images.count > 2 %>
        <div class="mt-2">
          <%= link_to "写真をすべて見る（#{@post.images.count}枚）",
              photos_shop_post_path(@shop, @post),
              class: "btn btn-outline-secondary btn-sm" %>
        </div>
      <% end %>
    <% end %>

  </div>
</div>